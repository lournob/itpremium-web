{
  "routes": [
    {
      "route": "/clientes",
      "rewrite": "/clientes.html"
    },
    {
      "route": "/clientes/",
      "rewrite": "/clientes.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/clientes.html", "/images/*.{png,jpg,gif,ico}", "/*.{css,scss,js}"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "no-referrer"
  }
}
